{
  "name": "gittrace",
  "version": "1.0.0",
  "description": "Git desktop client - visualize and manage your repositories",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite --config vite.config.ts"
  },
  "dependencies": {
    "@vueuse/core": "^10.7.0",
    "date-fns": "^3.3.0",
    "naive-ui": "^2.38.0",
    "pinia": "^2.1.0",
    "simple-git": "^3.22.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vue-tsc": "^2.0.0"
  },
  "build": {
    "appId": "com.gittrace.app",
    "productName": "GitTrace",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
